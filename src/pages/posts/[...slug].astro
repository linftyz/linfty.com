---
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { formatDate } from "@/utils/date";
import { getEntry } from "astro:content";
import { getEntries } from "astro:content";
import Link from "@/components/md/Link.astro";
import Img from "@/components/md/Img.astro";
import { Icon } from "astro-icon/components";
import Comments from "@/components/blocks/Comments.astro";
import TableOfContents from "@/components/blocks/TableOfContents.astro";
import PostRecommendations from "@/components/blocks/PostRecommendations.astro";
import { mdComponents } from "@/components/md";
import site from "@/config/site";
import { getPostNeighbors, getPosts, getRelatedPosts } from "@/utils/post";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const posts = await getPosts();
const { Content, headings } = await render(post);
const category = await getEntry(post.data.category);
const tags = (await getEntries(post.data.tags)).filter((value) => value);
const { newerPost, olderPost } = await getPostNeighbors(post, posts);
const relatedPosts = await getRelatedPosts(post, 3, posts);
---

<Layout title={post.data.title} description={post.data.summary}>
  <article
    class="animate-in fade-in mx-auto max-w-2xl overflow-x-hidden p-8 duration-1000 md:p-12"
  >
    <header class="mb-16 border-b border-border/50 pb-12">
      <div
        class="mb-6 flex items-center gap-2 text-[10px] font-bold tracking-[0.2em] text-primary uppercase"
      >
        <a href="/posts" class="hover:underline">{site.labels.postsTitle}</a>
        <span class="text-muted-foreground/30">/</span>
        <span>{site.labels.detailLabel}</span>
      </div>

      <h1
        class="mb-8 text-3xl leading-[1.4] font-bold text-foreground md:text-4xl"
      >
        {post.data.title}
      </h1>

      <div
        class="animate-in fade-in flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-[12px] tracking-tight text-muted-foreground duration-1000"
      >
        <span class="inline-flex items-center gap-1.5">
          <Icon name={"mdi:calendar-blank"} />
          <span
            id="post-date"
            data-updated={`${post.data.updatedAt ? site.labels.updatedPrefix + formatDate(post.data.updatedAt) : site.labels.notUpdated}`}
            >{formatDate(post.data.createdAt)}{
              post.data.updatedAt ? ` ${site.labels.editedSuffix}` : ""
            }</span
          >
        </span>

        <a
          href={`/categories/${category.data.slug}`}
          class="inline-flex cursor-pointer items-center gap-1.5 transition-colors hover:text-primary"
        >
          <Icon name={"mdi:category-outline"} />
          <span>{category.data.name}</span>
        </a>

        <span class="inline-flex items-center gap-3">
          <span class="inline-flex items-center gap-1.5">
            <span class="post-words-count">{post.body?.length}</span>
            <span class="text-[10px] uppercase opacity-90"
              >{site.labels.wordCount}</span
            >
          </span>

          <span class="inline-flex items-center gap-1.5">
            <span class="artalk-pv-count" data-page-key={Astro.url.pathname}
              >-</span
            >
            <span class="text-[10px] uppercase opacity-90"
              >{site.labels.viewCount}</span
            >
          </span>

          <span class="inline-flex items-center gap-1.5">
            <span
              class="artalk-comment-count"
              data-page-key={Astro.url.pathname}>-</span
            >
            <span class="text-[10px] uppercase opacity-90"
              >{site.labels.commentCount}</span
            >
          </span>
        </span>
      </div>
    </header>

    <TableOfContents headings={headings} />

    <div
      class:list={[
        "prose max-w-none dark:prose-invert",
        "prose-headings:tracking-tight",
        "prose-p:mb-8 prose-p:leading-loose prose-p:font-normal prose-p:text-muted-foreground",
        "prose-code:rounded-sm prose-code:bg-primary/15 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-primary prose-code:before:content-none prose-code:after:content-none",
        "prose-",
      ]}
      data-pagefind-body
    >
      <Content components={mdComponents} />
    </div>

    <div
      class="animate-in fade-in mt-12 mb-8 flex flex-wrap gap-2 duration-1000"
    >
      {
        tags.map((tag) => (
          <a
            href={`/tags/${tag.data.slug}`}
            class="group flex items-center gap-1.5 rounded-xl border border-border/50 bg-muted/30 px-3 py-1.5 transition-colors hover:border-primary/40 hover:bg-card"
          >
            <span class="font-mono text-xs text-primary/40 italic group-hover:text-primary">
              #
            </span>
            <span class="text-xs font-medium text-muted-foreground transition-colors group-hover:text-foreground">
              {tag.data.name}
            </span>
          </a>
        ))
      }
    </div>
  </article>

  <footer class="mx-auto mt-16 max-w-2xl space-y-12 px-8 md:px-12">
    <PostRecommendations
      newerPost={newerPost}
      olderPost={olderPost}
      relatedPosts={relatedPosts}
    />

    <div
      class="flex items-center justify-between border-t border-b border-border/50 py-5"
    >
      <a
        href="/posts"
        class="group flex items-center gap-2 text-sm text-muted-foreground hover:text-primary"
      >
        <span class="transition-transform group-hover:-translate-x-1">
          <Icon name="mdi:arrow-left" size={14} />
        </span>
        {site.labels.backToPosts}
      </a>
      <div
        class="font-mono text-[10px] tracking-widest text-muted-foreground/55 uppercase"
      >
        {site.labels.endOfPost}
      </div>
    </div>

    <Comments />
  </footer>
</Layout>

<style is:global>
  .prose p {
    text-align: justify;
    word-break: break-word;
  }

  .post-words-count,
  .artalk-pv-count,
  .artalk-comment-count {
    color: var(--primary);
    font-weight: 400;
    font-variant-numeric: tabular-nums;
    opacity: 0.8;
  }

  #post-date {
    position: relative;
  }

  #post-date:hover:before {
    position: absolute;
    content: attr(data-updated);
    top: -33px;
    width: fit-content;
    border: 1px solid var(--border);
    border-radius: 2rem;
    text-align: center;
    background-color: var(--muted);
    padding: 2px 4px;
    flex-wrap: nowrap;
    color: var(--muted-foreground);
  }
</style>
