---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import site from "@/config/site";
import ToolLogo from "@/components/blocks/ToolLogo.astro";

const tools = (await getCollection("tools")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout title={site.labels.toolsTitle} description={site.labels.toolsTitle}>
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-2xl p-8 duration-700 md:p-16"
    data-pagefind-body
  >
    <header class="mb-16">
      <h2 class="mb-4 text-3xl font-bold">{site.labels.toolsTitle}</h2>
      <p class="text-sm font-light text-muted-foreground italic">
        {site.labels.toolsDescription}
      </p>
    </header>

    <div class="space-y-10">
      {
        tools.map((category) => (
          <section>
            <h3 class="mb-4 text-[10px] font-bold tracking-[0.3em] text-primary uppercase">
              {category.data.name}
            </h3>
            <div class="grid grid-cols-2 gap-3 md:grid-cols-3">
              {category.data.items.map((item) => {
                const content = (
                  <>
                    <ToolLogo
                      name={item.name}
                      logo={item.logo}
                      icon={item.icon}
                      class="h-4 w-4 shrink-0 text-muted-foreground/60"
                    />
                    <span class="min-w-0 truncate font-medium transition-colors duration-300 group-hover:text-primary">
                      {item.name}
                    </span>
                  </>
                );

                return item.link ? (
                  <a
                    href={item.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-center gap-2.5 rounded-2xl border border-border/40 bg-muted/20 px-4 py-3 text-sm text-foreground/80 transition-[background-color,border-color,transform] duration-300 hover:-translate-y-0.5 hover:border-primary/25 hover:bg-card"
                  >
                    {content}
                  </a>
                ) : (
                  <div class="group flex items-center gap-2.5 rounded-2xl border border-border/40 bg-muted/20 px-4 py-3 text-sm text-foreground/80">
                    {content}
                  </div>
                );
              })}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</Layout>
