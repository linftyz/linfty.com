---
import { getPosts } from "@/utils/post";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import site from "@/config/site";

const allTags = await getCollection("tags");
const allPosts = await getPosts();

// Count posts per tag
const tagCounts = allPosts.reduce((acc: Record<string, number>, post) => {
  post.data.tags.forEach((tagRef) => {
    acc[tagRef.id] = (acc[tagRef.id] || 0) + 1;
  });
  return acc;
}, {});
---

<Layout title={site.labels.tagsTitle} description={site.labels.tagsDescription}>
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-2xl p-8 duration-700 md:p-16"
  >
    <header class="mb-16">
      <h2 class="mb-4 text-3xl font-bold">{site.labels.tagsTitle}</h2>
      <p class="mb-12 text-sm font-light text-muted-foreground italic">
        共 {allTags.length}
        {site.labels.tagsCountSuffix}
      </p>
    </header>

    <div class="grid grid-cols-2 gap-3 md:grid-cols-3">
      {
        allTags.map((tag) => (
          <a
            href={`/tags/${tag.data.slug}`}
            class="group flex flex-col gap-2 rounded-2xl border border-border/50 bg-muted/30 px-4 py-3 transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/40 hover:bg-card"
          >
            <div class="flex items-center gap-2">
              <span class="text-primary/60 italic group-hover:text-primary">
                #
              </span>
              <span class="text-sm font-medium text-foreground/80 group-hover:text-primary">
                {tag.data.name}
              </span>
            </div>
            <span class="font-mono text-[10px] font-bold text-muted-foreground/40 group-hover:text-primary/60">
              {tagCounts[tag.id] || 0} {site.labels.postsCountSuffix}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
