---
import Layout from "@/layouts/Layout.astro";
import { getPosts } from "@/utils/post";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import site from "@/config/site";

const allCategories = await getCollection("categories");
const allPosts = await getPosts();

const categoryCounts = allPosts.reduce((acc: Record<string, number>, post) => {
  const catId = post.data.category.id;
  acc[catId] = (acc[catId] || 0) + 1;
  return acc;
}, {});
---

<Layout
  title={site.labels.categoriesTitle}
  description={site.labels.categoriesDescription}
>
  <div
    class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-2xl p-8 duration-700 md:p-16"
    data-pagefind-body
  >
    <header class="mb-16">
      <h2 class="mb-4 text-3xl font-bold">{site.labels.categoriesTitle}</h2>
      <p class="mb-12 text-sm font-light text-muted-foreground italic">
        共 {allCategories.length}
        {site.labels.categoriesCountSuffix}
      </p>
    </header>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      {
        allCategories.map((cat) => (
          <a
            href={`/categories/${cat.data.slug}`}
            class="group rounded-2xl border border-border/50 bg-muted/20 p-5 transition-[background-color,border-color,transform] duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:bg-card"
          >
            <div class="min-w-0">
              <div class="mb-2 flex items-center gap-2">
                <Icon
                  name={cat.data.icon}
                  class="h-4 w-4 shrink-0 text-muted-foreground/60 transition-colors duration-300 group-hover:text-primary/80"
                />
                <h3 class="truncate text-base font-bold text-foreground/85 group-hover:text-primary">
                  {cat.data.name}
                </h3>
                <span class="shrink-0 font-mono text-[10px] text-muted-foreground/45 transition-colors duration-300 group-hover:text-primary/60">
                  {categoryCounts[cat.id] || 0}
                </span>
              </div>
              <p class="line-clamp-2 text-xs leading-relaxed text-muted-foreground">
                {cat.data.description || site.labels.noDescription}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
