---
import PostPreview from "@/components/blocks/PostPreview.astro";
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getPosts } from "@/utils/post";
import { Icon } from "astro-icon/components";
import site from "@/config/site";

export async function getStaticPaths() {
  const allCategories = await getCollection("categories");
  const allPosts = await getPosts();

  return allCategories.map((cat) => {
    const filteredPosts = allPosts.filter(
      (post) => post.data.category.id === cat.id,
    );
    return {
      params: { slug: cat.data.slug },
      props: { category: cat, posts: filteredPosts },
    };
  });
}

const { category, posts } = Astro.props;
---

<Layout
  title={`${site.labels.categoryPrefix}${category.data.name}`}
  description={`${category.data.name}`}
>
  <div class="mx-auto max-w-2xl p-8 md:p-12" data-pagefind-body>
    <header class="mb-16">
      <a
        href="/categories"
        class="mb-6 flex items-center gap-1 text-[10px] font-bold tracking-widest text-muted-foreground/60 uppercase transition-colors hover:text-primary"
      >
        <Icon name="mdi:arrow-left" size={14} />
        {site.labels.backToCategories}
      </a>

      <div class="mb-4 flex flex-wrap items-center gap-3">
        <Icon
          name={category.data.icon}
          class="h-6 w-6 shrink-0 text-muted-foreground/60"
        />
        <h2 class="text-3xl font-bold tracking-tight">
          <span class="text-primary">{category.data.name}</span>
        </h2>
        <span class="text-xs font-light text-muted-foreground/80">
          {posts.length} 篇文章
        </span>
      </div>

      <p
        class="max-w-xl text-sm leading-relaxed font-light text-muted-foreground italic"
      >
        {category.data.description || site.labels.noDescription}
      </p>
    </header>

    <div class="space-y-1">
      {posts.map((post) => <PostPreview post={post} />)}
    </div>
  </div>
</Layout>
