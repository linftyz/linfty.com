---
import { siteConfig } from "@/config/site";
import type { SeoMeta } from "@/types/site";

interface Props extends SeoMeta {}

const {
  title = siteConfig.defaultSeo.title,
  description = siteConfig.defaultSeo.description,
  canonical = Astro.url.pathname,
  ogImage = siteConfig.defaultSeo.ogImage,
  type = siteConfig.defaultSeo.type,
  noindex = false,
} = Astro.props;

const pageTitle =
  title === siteConfig.name ? siteConfig.name : `${title} | ${siteConfig.name}`;
const canonicalUrl = new URL(canonical, siteConfig.url).toString();
const ogImageUrl = ogImage
  ? new URL(ogImage, siteConfig.url).toString()
  : undefined;
---

<!-- Document metadata: encoding, responsive viewport, and generator info. -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<meta name="color-scheme" content="light dark" />

<!-- Site icons: browser tab and bookmark icons. -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />

<!-- Primary SEO: search result title, description, author, and canonical URL. -->
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author.name} />
<link rel="canonical" href={canonicalUrl} />

<!-- Crawling control: opt specific pages out of indexing when needed. -->
{noindex && <meta name="robots" content="noindex,nofollow" />}

<!-- Open Graph: rich previews for social platforms and messaging apps. -->
<meta property="og:locale" content={siteConfig.locale} />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

<!-- Twitter Card: preview metadata for X/Twitter and compatible clients. -->
<meta
  name="twitter:card"
  content={ogImageUrl ? "summary_large_image" : "summary"}
/>
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

<!-- Browser title: visible in tabs, bookmarks, and history. -->
<title>{pageTitle}</title>

<!-- Extension point: page-specific meta tags, preload hints, or structured data. -->
<slot />
