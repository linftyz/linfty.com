---

---

<button
  id="theme-toggle"
  class="relative flex h-6 w-10 items-center rounded-full bg-muted p-1 transition-colors duration-200"
  title="切换主题"
>
  <div
    class="h-4 w-4 translate-x-0 rounded-full bg-background shadow-sm transition-transform duration-200 dark:translate-x-4"
  >
  </div>
</button>

<script>
  document.addEventListener("astro:page-load", () => {
    const getPreferredTheme = () => {
      const localStorageTheme = localStorage?.getItem("theme") ?? "";
      if (["dark", "light"].includes(localStorageTheme)) {
        return localStorageTheme;
      }
      if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
        return "dark";
      }
      return "light";
    };

    const setTheme = (theme: "dark" | "light") => {
      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }

      window.localStorage.setItem("theme", theme);
    };

    const theme = getPreferredTheme();

    setTheme(theme);

    const applyThemeTransition = (callback: () => void, duration = 220) => {
      document.documentElement.classList.add("theme-switching");
      callback();

      window.setTimeout(() => {
        document.documentElement.classList.remove("theme-switching");
      }, duration);
    };

    const handleToggleClick = async (event: MouseEvent) => {
      const element = document.documentElement;
      const nextTheme = element.classList.contains("dark") ? "light" : "dark";

      if (
        !document.startViewTransition ||
        window.matchMedia("(prefers-reduced-motion: reduce)").matches
      ) {
        applyThemeTransition(() => setTheme(nextTheme), 360);
        return;
      }

      const toggle =
        event.currentTarget instanceof HTMLElement
          ? event.currentTarget
          : document.getElementById("theme-toggle");
      const rect = toggle?.getBoundingClientRect();
      const x = rect ? rect.left + rect.width / 2 : window.innerWidth / 2;
      const y = rect ? rect.top + rect.height / 2 : window.innerHeight / 2;
      const endRadius = Math.hypot(
        Math.max(x, window.innerWidth - x),
        Math.max(y, window.innerHeight - y),
      );
      const duration = 820;

      const transition = document.startViewTransition(() => {
        setTheme(nextTheme);
      });

      await transition.ready;

      document.documentElement.classList.add("theme-switching");

      const newThemeAnimation = document.documentElement.animate(
        {
          clipPath: [
            `circle(0px at ${x}px ${y}px)`,
            `circle(${endRadius + 16}px at ${x}px ${y}px)`,
          ],
          opacity: [0.9, 1],
          transform: ["scale(1.004)", "scale(1)"],
        },
        {
          duration,
          easing: "cubic-bezier(0.22, 1, 0.36, 1)",
          pseudoElement: "::view-transition-new(root)",
        },
      );

      const oldThemeAnimation = document.documentElement.animate(
        {
          opacity: [1, 0.99],
          transform: ["scale(1)", "scale(0.998)"],
        },
        {
          duration: 280,
          easing: "cubic-bezier(0.22, 1, 0.36, 1)",
          pseudoElement: "::view-transition-old(root)",
        },
      );

      await Promise.allSettled([
        newThemeAnimation.finished,
        oldThemeAnimation.finished,
      ]);

      document.documentElement.classList.remove("theme-switching");
    };

    const themeToggle = document.getElementById("theme-toggle");
    themeToggle?.addEventListener("click", handleToggleClick);
  });
</script>

<script is:inline>
  function applyTheme() {
    localStorage.theme === "dark"
      ? document.documentElement.classList.add("dark")
      : document.documentElement.classList.remove("dark");
  }

  document.addEventListener("astro:after-swap", applyTheme);
  applyTheme();
</script>
