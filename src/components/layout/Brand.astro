---
import site from "@/config/site";
import { Image } from "astro:assets";
---

<div class="mb-5 flex items-center gap-3 md:mb-6">
  <div
    class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-muted text-lg font-bold text-primary-foreground md:h-10 md:w-10"
  >
    <Image
      loading={"eager"}
      src={site.meta.logo}
      alt={"站点标志"}
      width={44}
      height={44}
    />
  </div>
  <div class="min-w-0">
    <h1
      data-pagefind-ignore
      class="truncate text-base font-bold tracking-tight text-foreground md:text-lg"
    >
      {site.meta.title}
    </h1>
    <p
      class="mt-1 hidden text-[11px] leading-snug text-muted-foreground/70 md:block"
    >
      {site.meta.description}
    </p>
  </div>
</div>
