---
import site from "@/config/site";
import { Image } from "astro:assets";
---

<div
  class="mb-5 flex items-center gap-3 md:mb-10 md:flex-col md:items-start md:gap-0"
>
  <div
    class="flex h-9 w-9 items-center justify-center rounded-xl bg-muted text-lg font-bold text-primary-foreground md:h-11 md:w-11"
  >
    <Image
      loading={"eager"}
      src={site.meta.logo}
      alt={"站点标志"}
      width={44}
      height={44}
    />
  </div>
  <div class="md:mt-8">
    <h1
      data-pagefind-ignore
      class="text-base font-bold tracking-tight text-foreground md:text-xl"
    >
      {site.meta.title}
    </h1>
    <p class="mt-2 hidden text-xs text-muted-foreground/70 md:block">
      {site.meta.description}
    </p>
  </div>
</div>
