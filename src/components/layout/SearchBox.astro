---
import { Icon } from "astro-icon/components";
import site from "@/config/site";
---

<div class="mb-4">
  <button
    id="search-trigger"
    type="button"
    class="group flex w-full items-center justify-between rounded-xl border border-border/50 bg-muted/30 px-3 py-3 text-muted-foreground hover:border-primary/30 hover:text-primary"
    title={site.labels.searchTrigger}
    aria-controls="search-modal"
    aria-expanded="false"
    aria-haspopup="dialog"
  >
    <div class="flex items-center gap-2">
      <Icon name="mdi:search" />
      <span class="text-xs font-medium">{site.labels.searchTrigger}</span>
    </div>
    <kbd
      class="hidden items-center gap-1 rounded border border-border/50 px-1.5 py-0.5 font-display text-[12px] opacity-50 md:flex"
    >
      <Icon name="mdi:apple-keyboard-command" size={12} /> K
    </kbd>
  </button>
</div>
