---
import site from "@/config/site";
import { Icon } from "astro-icon/components";

const currentPath = Astro.url.pathname;
---

<nav
  class="flex flex-1 flex-wrap gap-3 overflow-x-auto max-md:justify-between md:flex-none md:flex-col md:flex-nowrap md:gap-2 md:overflow-x-visible"
>
  {
    site.navigation.map((item) => {
      const isActive =
        currentPath === item.href ||
        (item.href !== "/" && currentPath.startsWith(item.href));
      return (
        <a
          href={item.href}
          class:list={[
            "group flex min-w-[5.75rem] items-center justify-center rounded-2xl border border-transparent px-3 py-2.5 transition-[background-color,border-color,color,transform] duration-200 active:bg-muted/60 md:h-10 md:min-w-0 md:justify-between md:rounded-xl md:px-3 md:py-0",
            isActive
              ? "border-primary/20 border-l-primary/60 bg-primary/10 md:hover:bg-primary/12"
              : "hover:bg-muted/50 md:text-muted-foreground",
          ]}
        >
          <div class="flex flex-col">
            <span
              class:list={[
                "text-sm font-bold",
                isActive
                  ? "text-primary"
                  : "text-muted-foreground group-hover:text-primary",
              ]}
            >
              {item.name}
            </span>
            <span
              class:list={[
                "text-[10px] tracking-widest uppercase md:hidden",
                isActive ? "text-primary/75" : "text-muted-foreground/65",
              ]}
            >
              {item.subtitle}
            </span>
          </div>

          <span
            class:list={[
              "hidden text-primary transition-[opacity,transform] duration-200 md:block",
              isActive
                ? "opacity-100"
                : "-translate-x-1 opacity-0 group-hover:translate-x-0 group-hover:opacity-80",
            ]}
          >
            <Icon name="mdi:arrow-right" />
          </span>
        </a>
      );
    })
  }
</nav>
