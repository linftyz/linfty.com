---
import { render } from "astro:content";
import { formatDate } from "@/utils/date";
import type { MemoEntry } from "@/utils/memo";
import { mdComponents } from "@/components/md";
import { Icon } from "astro-icon/components";
import site from "@/config/site";

interface Props {
  memo: MemoEntry;
  compact?: boolean;
}

const { memo, compact = false } = Astro.props;
const { Content } = await render(memo);
const memoUrl = `/memos#${memo.id}`;
const memoDateFormat =
  memo.data.createdAt.getHours() === 0 && memo.data.createdAt.getMinutes() === 0
    ? "YYYY.MM.DD"
    : "YYYY.MM.DD HH:mm";
---

<article
  id={memo.id}
  class:list={[
    "memo-item group scroll-mt-8 border-b border-border/40 py-7 last:border-0",
    compact && "py-5",
  ]}
>
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <a
      href={memoUrl}
      class="font-mono text-[11px] tracking-tight text-muted-foreground/65 tabular-nums transition-colors hover:text-primary"
      aria-label={`${site.labels.memoPermalink} ${formatDate(memo.data.createdAt)}`}
    >
      {formatDate(memo.data.createdAt, memoDateFormat)}
    </a>

    <a
      href={memoUrl}
      class="text-muted-foreground/55 transition-[color,transform] hover:text-primary active:scale-[0.96]"
      title={site.labels.memoPermalink}
      aria-label={site.labels.memoPermalink}
      data-memo-permalink
      data-copy-message={site.labels.memoLinkCopied}
    >
      <Icon name="mdi:link" class="h-3.5 w-3.5" />
    </a>
  </div>

  <div
    class:list={[
      "prose max-w-none dark:prose-invert",
      "prose-p:my-3 prose-p:leading-loose prose-p:text-muted-foreground",
      "prose-a:text-foreground prose-a:decoration-primary/30 prose-a:underline-offset-4 hover:prose-a:text-primary",
      "prose-code:rounded-sm prose-code:bg-primary/15 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-primary prose-code:before:content-none prose-code:after:content-none",
      compact && "memo-compact",
    ]}
  >
    <Content components={mdComponents} />
  </div>

  {
    memo.data.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {memo.data.tags.map((tag) => (
          <span class="rounded-full border border-border/50 bg-muted/20 px-2.5 py-1 font-mono text-[10px] text-muted-foreground/60">
            #{tag}
          </span>
        ))}
      </div>
    )
  }
</article>

<style>
  .memo-compact {
    max-height: 10rem;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, black 72%, transparent);
  }

  .memo-item:target {
    border-radius: 1rem;
    background: oklch(from var(--primary) l c h / 0.05);
    box-shadow: 0 0 0 1px oklch(from var(--primary) l c h / 0.16) inset;
    padding-inline: 1rem;
  }
</style>

<script>
  function bindMemoPermalinks() {
    const links = document.querySelectorAll<HTMLAnchorElement>(
      "[data-memo-permalink]",
    );

    links.forEach((link) => {
      if (link.dataset.copyBound === "true") return;
      link.dataset.copyBound = "true";

      link.addEventListener("click", async (event) => {
        if (
          event.button !== 0 ||
          event.metaKey ||
          event.ctrlKey ||
          event.shiftKey ||
          event.altKey ||
          !navigator.clipboard ||
          !window.isSecureContext
        ) {
          return;
        }

        event.preventDefault();

        const memoUrl = new URL(link.href, window.location.href);

        try {
          await navigator.clipboard.writeText(memoUrl.toString());
          window.history.replaceState(null, "", memoUrl.hash);
          window.showToast?.(
            link.dataset.copyMessage || "链接已复制",
            "success",
          );
        } catch {
          window.location.href = link.href;
        }
      });
    });
  }

  bindMemoPermalinks();
  document.addEventListener("astro:page-load", bindMemoPermalinks);
</script>
