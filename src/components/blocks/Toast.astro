---
import { Icon } from "astro-icon/components";
---

<div id="toast-icons" class="hidden" aria-hidden="true">
  <template data-toast-icon="success">
    <Icon name="mdi:check" class="h-4 w-4" />
  </template>
  <template data-toast-icon="error">
    <Icon name="mdi:close" class="h-4 w-4" />
  </template>
  <template data-toast-icon="warning">
    <Icon name="mdi:alert-outline" class="h-4 w-4" />
  </template>
  <template data-toast-icon="info">
    <Icon name="mdi:information-outline" class="h-4 w-4" />
  </template>
</div>

<div
  id="toast-container"
  class="pointer-events-none fixed bottom-12 left-1/2 z-999 flex -translate-x-1/2 flex-col items-center gap-3"
>
</div>

<script>
  class SageToast {
    private static config = {
      success: {
        icon: "success",
        color: "var(--callout-tip)",
        label: "成功",
      },
      error: {
        icon: "error",
        color: "var(--callout-caution)",
        label: "错误",
      },
      warning: {
        icon: "warning",
        color: "var(--callout-warning)",
        label: "警告",
      },
      info: {
        icon: "info",
        color: "var(--callout-note)",
        label: "提示",
      },
    };

    static show(
      message: string,
      type: "success" | "error" | "warning" | "info" = "success",
    ) {
      const container = document.getElementById("toast-container");
      if (!container) return;

      const settings = this.config[type] || this.config.success;
      const iconTemplate = document.querySelector(
        `#toast-icons template[data-toast-icon="${settings.icon}"]`,
      );
      const toast = document.createElement("div");

      // Rounded corners, background uses 10% opacity of the corresponding color
      toast.className = `
        flex items-center gap-3 px-6 py-3 rounded-[2.5rem] 
        bg-card border-2 shadow-main
        animate-in pointer-events-auto backdrop-blur-md
      `;

      // Set border color dynamically
      toast.style.borderColor = `oklch(from ${settings.color} l c h / 0.3)`;

      toast.innerHTML = `
        <div class="w-6 h-6 rounded-full flex items-center justify-center" style="background: oklch(from ${settings.color} l c h / 0.15); color: ${settings.color}">
          ${iconTemplate?.innerHTML || ""}
        </div>
        <div class="flex flex-col">
          <span class="text-xs font-bold uppercase tracking-tighter opacity-40" style="color: ${settings.color}">${settings.label}</span>
          <span class="text-sm font-bold tracking-tight text-foreground/90">${message}</span>
        </div>
      `;

      container.appendChild(toast);

      // Auto-dismiss after 3.5s
      setTimeout(() => {
        toast.style.opacity = "0";
        toast.style.transform = "translateY(-1rem) scale(0.9)";
        toast.style.transition = "all 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
        setTimeout(() => toast.remove(), 500);
      }, 3500);
    }
  }

  // Mount globally
  (window as any).showToast = (
    msg: string,
    type: "success" | "error" | "warning" | "info" = "success",
  ) => SageToast.show(msg, type);
</script>
