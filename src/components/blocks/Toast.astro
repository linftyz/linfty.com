---
import { Icon } from "astro-icon/components";
---

<div id="toast-icons" class="hidden" aria-hidden="true">
  <template data-toast-icon="success">
    <Icon name="mdi:check" class="h-4 w-4" />
  </template>
  <template data-toast-icon="error">
    <Icon name="mdi:close" class="h-4 w-4" />
  </template>
  <template data-toast-icon="warning">
    <Icon name="mdi:alert-outline" class="h-4 w-4" />
  </template>
  <template data-toast-icon="info">
    <Icon name="mdi:information-outline" class="h-4 w-4" />
  </template>
</div>

<div
  id="toast-container"
  class="pointer-events-none fixed bottom-12 left-1/2 z-999 flex -translate-x-1/2 flex-col items-center gap-3"
>
</div>

<script>
  class SageToast {
    private static config = {
      success: {
        icon: "success",
        color: "var(--callout-tip)",
        label: "成功",
      },
      error: {
        icon: "error",
        color: "var(--callout-caution)",
        label: "错误",
      },
      warning: {
        icon: "warning",
        color: "var(--callout-warning)",
        label: "警告",
      },
      info: {
        icon: "info",
        color: "var(--callout-note)",
        label: "提示",
      },
    };

    static show(
      message: string,
      type: "success" | "error" | "warning" | "info" = "success",
    ) {
      const container = document.getElementById("toast-container");
      if (!container) return;

      const settings = this.config[type] || this.config.success;
      const iconTemplate = document.querySelector(
        `#toast-icons template[data-toast-icon="${settings.icon}"]`,
      );
      const toast = document.createElement("div");
      const icon = document.createElement("div");
      const content = document.createElement("div");
      const label = document.createElement("span");
      const messageNode = document.createElement("span");

      // Rounded corners, background uses 10% opacity of the corresponding color
      toast.className = `
        flex items-center gap-3 px-6 py-3 rounded-[2.5rem] 
        bg-card border-2 shadow-main
        animate-in pointer-events-auto backdrop-blur-md
      `;

      // Set border color dynamically
      toast.style.borderColor = `oklch(from ${settings.color} l c h / 0.3)`;

      icon.className = "flex h-6 w-6 items-center justify-center rounded-full";
      icon.style.background = `oklch(from ${settings.color} l c h / 0.15)`;
      icon.style.color = settings.color;
      icon.append(iconTemplate?.content.cloneNode(true) || "");

      content.className = "flex flex-col";

      label.className =
        "text-xs font-bold tracking-tighter uppercase opacity-40";
      label.style.color = settings.color;
      label.textContent = settings.label;

      messageNode.className =
        "text-sm font-bold tracking-tight text-foreground/90";
      messageNode.textContent = message;

      content.append(label, messageNode);
      toast.append(icon, content);

      container.appendChild(toast);

      // Auto-dismiss after 3.5s
      setTimeout(() => {
        toast.style.opacity = "0";
        toast.style.transform = "translateY(-1rem) scale(0.9)";
        toast.style.transition =
          "opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1), transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
        setTimeout(() => toast.remove(), 500);
      }, 3500);
    }
  }

  // Mount globally
  (window as any).showToast = (
    msg: string,
    type: "success" | "error" | "warning" | "info" = "success",
  ) => SageToast.show(msg, type);
</script>
