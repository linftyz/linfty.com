---
interface Props {
  type?: "note" | "tip" | "important" | "warning" | "caution";
  title?: string;
}

const { type = "note", title } = Astro.props;

const config = {
  note: {
    label: "NOTE",
  },
  tip: {
    label: "TIP",
  },
  important: {
    label: "IMPORTANT",
  },
  warning: {
    label: "WARNING",
  },
  caution: {
    label: "CAUTION",
  },
};

const current = config[type] || config.note;
const label = title || current.label;
const customTitle = Boolean(title);
---

<aside class="md-callout not-prose" data-callout={type}>
  <div
    class="md-callout-title"
    data-callout-custom-title={customTitle ? "true" : "false"}
  >
    <span class="md-callout-icon" aria-hidden="true"></span>
    <span>{label}</span>
  </div>
  <slot />
</aside>
