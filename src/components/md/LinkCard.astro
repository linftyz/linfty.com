---
import {
  createRequestMemoryCache,
  hasResolvedValue,
  readPendingRequest,
  readResolvedValue,
  trackPendingRequest,
  writeResolvedValue,
} from "@/utils/card-cache";

interface Props {
  url: string;
  title?: string;
  description?: string;
  image?: string;
}

interface LinkMetadata {
  title: string;
  description: string;
  image: string;
}

const linkMetadataCache = createRequestMemoryCache<LinkMetadata>();
const LINK_CARD_REQUEST_TIMEOUT = 2500;

const { url, title, description, image } = Astro.props;

function cleanupText(value = ""): string {
  return value
    .replaceAll("&amp;", "&")
    .replaceAll("&lt;", "<")
    .replaceAll("&gt;", ">")
    .replaceAll("&quot;", '"')
    .replaceAll("&#39;", "'")
    .replace(/\s+/g, " ")
    .trim();
}

function parseAttributes(tag: string): Record<string, string> {
  const attributes: Record<string, string> = {};
  const matches = tag.matchAll(
    /([:@A-Za-z0-9_-]+)\s*=\s*(?:"([^"]*)"|'([^']*)'|([^\s>]+))/g,
  );

  for (const match of matches) {
    const [, name, quotedDouble, quotedSingle, bareValue] = match;
    attributes[name.toLowerCase()] = cleanupText(
      quotedDouble || quotedSingle || bareValue || "",
    );
  }

  return attributes;
}

function pickFirst(...values: Array<string | undefined>): string {
  return values.find((value) => value && value.trim()) || "";
}

function resolveAssetUrl(value: string, baseUrl: string): string {
  if (!value) {
    return "";
  }

  try {
    return new URL(value, baseUrl).toString();
  } catch {
    return value;
  }
}

function extractMetadata(html: string, baseUrl: string): LinkMetadata {
  const metaMap = new Map<string, string>();
  const metaTags = html.match(/<meta\b[^>]*>/gi) || [];

  for (const tag of metaTags) {
    const attrs = parseAttributes(tag);
    const key = (attrs.property || attrs.name || "").toLowerCase();
    const content = attrs.content || "";

    if (key && content && !metaMap.has(key)) {
      metaMap.set(key, content);
    }
  }

  const titleMatch = html.match(/<title[^>]*>([\s\S]*?)<\/title>/i);
  const parsedTitle = titleMatch ? cleanupText(titleMatch[1]) : "";

  return {
    title: pickFirst(
      metaMap.get("og:title"),
      metaMap.get("twitter:title"),
      parsedTitle,
    ),
    description: pickFirst(
      metaMap.get("og:description"),
      metaMap.get("twitter:description"),
      metaMap.get("description"),
    ),
    image: resolveAssetUrl(
      pickFirst(metaMap.get("og:image"), metaMap.get("twitter:image")),
      baseUrl,
    ),
  };
}

async function requestLinkMetadata(url: string): Promise<LinkMetadata | null> {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), LINK_CARD_REQUEST_TIMEOUT);

  try {
    const response = await fetch(url, {
      headers: {
        accept: "text/html,application/xhtml+xml",
        "user-agent": "Mozilla/5.0 LinftyLinkCard/1.0",
      },
      redirect: "follow",
      signal: controller.signal,
    });

    if (!response.ok) {
      return null;
    }

    const contentType = response.headers.get("content-type") || "";
    if (!contentType.includes("text/html")) {
      return null;
    }

    const html = await response.text();
    return extractMetadata(html, response.url || url);
  } catch {
    return null;
  } finally {
    clearTimeout(timer);
  }
}

async function getLinkMetadata(url: string): Promise<LinkMetadata | null> {
  if (hasResolvedValue(linkMetadataCache, url)) {
    return readResolvedValue(linkMetadataCache, url) ?? null;
  }

  const pendingRequest = readPendingRequest(linkMetadataCache, url);
  if (pendingRequest) {
    return pendingRequest;
  }

  const request = requestLinkMetadata(url).then((metadata) =>
    writeResolvedValue(linkMetadataCache, url, metadata),
  );

  return trackPendingRequest(linkMetadataCache, url, request);
}

function getLinkDomainLabel(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, "");
  } catch {
    return url;
  }
}

const metadata = await getLinkMetadata(url);
const finalTitle = title || metadata?.title || getLinkDomainLabel(url);
const finalDescription = description || metadata?.description || "";
const finalImage = image || metadata?.image || "";
const domainLabel = getLinkDomainLabel(url);
---

<div class="link-card-wrapper not-prose">
  <a
    href={url}
    class="link-card"
    target="_blank"
    rel="noopener noreferrer"
    title={finalTitle}
  >
    <div class="link-card-content">
      <div class="link-card-url">{domainLabel}</div>
      <p class="link-card-title">{finalTitle}</p>
      {
        finalDescription && (
          <p class="link-card-description">{finalDescription}</p>
        )
      }
    </div>
    {
      finalImage && (
        <div class="link-card-image-outer" aria-hidden="true">
          <div class="link-card-image">
            <img src={finalImage} alt="" loading="lazy" decoding="async" />
          </div>
        </div>
      )
    }
  </a>
</div>

<style>
  .link-card-wrapper {
    margin: 2rem 0;
  }

  .link-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: stretch;
    border: 1px solid oklch(from var(--border) l c h / 0.9);
    border-radius: 1.2rem;
    background: linear-gradient(
      180deg,
      oklch(from var(--card) l c h / 0.98),
      oklch(from var(--muted) l c h / 0.16)
    );
    padding: 1rem 1.05rem;
    text-decoration: none;
    box-shadow:
      0 1px 0 oklch(from var(--background) l c h / 0.65) inset,
      0 18px 36px -28px oklch(from var(--foreground) l c h / 0.18);
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .link-card:hover {
    border-color: oklch(from var(--primary) l c h / 0.28);
    transform: translateY(-1px);
    box-shadow:
      0 1px 0 oklch(from var(--background) l c h / 0.75) inset,
      0 24px 44px -30px oklch(from var(--primary) l c h / 0.28);
  }

  .link-card-content {
    min-width: 0;
    display: grid;
    gap: 0.38rem;
    align-content: start;
  }

  .link-card-url {
    color: oklch(from var(--foreground) l c h / 0.42);
    font-size: 0.77rem;
    font-weight: 700;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  .link-card-title {
    margin: 0;
    color: var(--foreground);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.45;
    text-align: left;
    text-wrap: pretty;
    word-break: normal;
  }

  .link-card-description {
    margin: 0;
    color: var(--muted-foreground);
    font-size: 0.92rem;
    line-height: 1.65;
    text-align: left;
    text-wrap: pretty;
    word-break: normal;
  }

  .link-card-image-outer {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .link-card-image {
    width: 4.5rem;
    height: 4.5rem;
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid oklch(from var(--border) l c h / 0.85);
    background: oklch(from var(--muted) l c h / 0.24);
  }

  .link-card-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 640px) {
    .link-card {
      grid-template-columns: 1fr;
    }

    .link-card-image-outer {
      justify-content: flex-start;
    }
  }
</style>
