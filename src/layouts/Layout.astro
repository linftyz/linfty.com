---
import Sidebar from "@/components/layout/Sidebar.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { HeadProps } from "@/types";

type Props = HeadProps;

const head = Astro.props;
---

<BaseLayout {...head}>
  <div
    class="relative flex h-auto w-full max-w-6xl flex-col overflow-hidden rounded-none border border-border/70 bg-card/90 shadow-main md:h-[min(50rem,calc(100dvh-3rem))] md:flex-row md:rounded-[2rem]"
  >
    <Sidebar />

    <main
      class="custom-scrollbar min-h-0 flex-1 overflow-x-hidden overflow-y-auto"
    >
      <slot />
    </main>
  </div>
</BaseLayout>
